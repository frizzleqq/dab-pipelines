{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT machine_id) AS total_machines, SUM(total_readings) AS total_readings, SUM(anomaly_count) AS total_anomalies, ROUND(SUM(anomaly_count) * 100.0 / NULLIF(SUM(total_readings), 0), 1) AS anomaly_rate_pct, ROUND(SUM(total_power_consumption), 0) AS total_power_kwh FROM fact_sensor_agg"
      ]
    },
    {
      "name": "ds_fleet",
      "displayName": "Machine Fleet",
      "queryLines": [
        "SELECT machine_id, machine_name, machine_type, machine_status, machine_location, manufacturer, CAST(installation_date AS DATE) AS installation_date, max_temperature, max_pressure FROM dim_machine"
      ]
    },
    {
      "name": "ds_daily",
      "displayName": "Daily Trend",
      "queryLines": [
        "SELECT machine_date, SUM(total_readings) AS total_readings, SUM(anomaly_count) AS total_anomalies, ROUND(SUM(anomaly_count) * 100.0 / NULLIF(SUM(total_readings), 0), 1) AS anomaly_rate_pct, ROUND(SUM(total_power_consumption), 0) AS total_power_kwh FROM fact_sensor_agg GROUP BY machine_date ORDER BY machine_date"
      ]
    },
    {
      "name": "ds_machine_daily",
      "displayName": "Machine Daily Metrics",
      "queryLines": [
        "SELECT a.machine_date, a.machine_id, COALESCE(a.machine_type, m.machine_type) AS machine_type, COALESCE(a.machine_status, m.machine_status) AS machine_status, a.total_readings, a.anomaly_count, ROUND(a.anomaly_count * 100.0 / NULLIF(a.total_readings, 0), 1) AS anomaly_rate_pct, a.avg_temperature, a.avg_power_consumption, a.total_power_consumption FROM fact_sensor_agg a LEFT JOIN dim_machine m ON a.machine_id = m.machine_id"
      ]
    },
    {
      "name": "ds_errors",
      "displayName": "Error Distribution",
      "queryLines": [
        "SELECT error_code, COUNT(*) AS error_count FROM fact_sensor WHERE error_code IS NOT NULL GROUP BY error_code ORDER BY error_count DESC"
      ]
    }
  ],
  "pages": [
